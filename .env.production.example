# Copie para .env.production (ou .env ao usar docker compose) na VPS ou na máquina de build.
# Nunca commite valores reais. O build do Vite embute apenas variáveis prefixadas com VITE_.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anon_publica

# Opcional: atalho quando o usuário digita "admin" no e-mail de login
# VITE_DEFAULT_ADMIN_EMAIL=admin@suaempresa.com

# Produção: mantenha 0 salvo que queira cadastro público
VITE_ALLOW_SIGNUP=0

# Produção: mantenha 0 — evita recarregar mockData após reset do banco
VITE_SEED_DEMO_DATA=0

# Se o app ficar em subpasta (ex.: https://dominio.com/attivos/), use:
# VITE_BASE_PATH=/attivos

# Docker Compose: porta publicada no host (opcional)
# ATTIVOS_HTTP_PORT=8080
