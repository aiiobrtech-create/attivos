# Supabase (Vite expõe variáveis que começam com VITE_)
VITE_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
VITE_SUPABASE_ANON_KEY="SUA_ANON_KEY"

# Se publicar em subpasta (ex.: /attivos/), defina no build de produção — ver deploy/README.md
# VITE_BASE_PATH="/"

# Atalho de login: se o usuário digitar "admin" no campo e-mail, o app usa este endereço
VITE_DEFAULT_ADMIN_EMAIL="seu-admin@empresa.com"

# Cadastro público na tela de login (1/true = exibe aba "Criar conta")
VITE_ALLOW_SIGNUP="0"

# Se 1/true: ao logar, se categorias E ativos estiverem vazios no Supabase, envia mockData.ts (só para demo/dev).
# Em implantação deixe desligado — senão o app “reenche” o banco após um reset.
# VITE_SEED_DEMO_DATA=0

# --- Só para o script `npm run seed:admin` (nunca exponha a service_role no Vite) ---
# SUPABASE_SERVICE_ROLE_KEY="cole_a_service_role_aqui"
# ATTIVOS_ADMIN_EMAIL="renan@reetech.com.br"
# ATTIVOS_ADMIN_PASSWORD="sua_senha"
# ATTIVOS_ADMIN_NAME="Renan"

# --- `npm run reset:data` — apaga patrimônio/cadastros no Supabase (exige confirmação) ---
# ATTIVOS_RESET_CONFIRM=YES

# --- `npm run delete:assets -- --yes` — apaga só ativos + manutenções/movimentações/baixas/histórico (mantém categorias, locais, CC) ---

# Opcional: chave do Google Maps Embed API (mapa na ficha/cadastro do ativo). Sem ela, o iframe usa embed genérico.
# VITE_GOOGLE_MAPS_API_KEY=""

# Opcional: desliga HMR
# DISABLE_HMR=true
